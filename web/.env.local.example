# FIT web dashboard environment.
# Copy to .env.local. `.env.local` overrides `.env.production` for dev and build.
#
# Default: same-origin path proxied to the API by Next.js (no CORS anywhere).
NEXT_PUBLIC_API_URL=/api/v1
# Server-side proxy target (not exposed to the browser):
API_PROXY_TARGET=https://api.fit.fobs.dev
#
# Alternatives (set NEXT_PUBLIC_API_URL to an absolute URL to bypass the proxy
# and call the API directly — requires the API's CORS to allow this origin):
#   NEXT_PUBLIC_API_URL=https://api.fit.fobs.dev/api/v1
#   NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1   # local backend
