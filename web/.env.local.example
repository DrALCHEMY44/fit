# FIT web dashboard environment.
# Copy to .env.local. `.env.local` overrides `.env.production` for both dev and build.
#
# Base URL of the FIT Laravel API (no trailing slash).
# Live API:
NEXT_PUBLIC_API_URL=https://api.fit.fobs.dev/api/v1
#
# For a locally-running backend instead, use:
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
