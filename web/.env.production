# FIT web dashboard — production environment (committed; NEXT_PUBLIC_* is not secret).
# Used by `next build` / `next start`. The value is inlined into the client bundle.
#
# Same-origin path: the browser calls /api/v1 on the web's own origin and the
# Next.js server proxies it to the FIT API (see next.config.js). No CORS needed.
NEXT_PUBLIC_API_URL=/api/v1
#
# Server-side proxy target (not exposed to the browser). Change if the API moves.
API_PROXY_TARGET=https://api.fit.fobs.dev
